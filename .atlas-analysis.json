  "keyFeatures": [
    "90+ cross-platform event hooks covering player, lifecycle, interaction, block, and client events",
    "Platform-agnostic registry abstraction with DeferredRegister and Registrar APIs",
    "Unified networking API for client-server packet communication on both Fabric and Forge",
    "@ExpectPlatform annotation for writing platform-specific code with a single common interface",
    "Platform detection utilities (isFabric(), isForge(), getEnvironment()) for runtime branching",
    "Built-in abstractions for fluids, items, blocks, and creative tabs"
  ],
